<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Redirigir a Amazon</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            background-color: #f9f9f9;
        }
        .container {
            text-align: center;
            background: #fff;
            padding: 20px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            border-radius: 8px;
        }
        input {
            width: 100%;
            padding: 10px;
            margin-bottom: 10px;
            border: 1px solid #ccc;
            border-radius: 4px;
        }
        button {
            padding: 10px 20px;
            background-color: #0073b1;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }
        button:hover {
            background-color: #005f8c;
        }
        .message {
            margin-top: 10px;
            font-size: 0.9em;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Redirigir enlace Amazon</h1>
        <p>Pega un enlace de Amazon para añadir tu código de afiliado:</p>
        <input type="text" id="amazonLink" placeholder="Pega el enlace de Amazon aquí">
        <button onclick="redirectWithAffiliate()">Redirigir</button>
        <p class="message" id="message"></p>
    </div>
    <script>
        function redirectWithAffiliate() {
            const input = document.getElementById('amazonLink').value;
            const message = document.getElementById('message');
            try {
                if (!input.includes('amazon.')) {
                    message.textContent = 'Por favor, ingresa un enlace válido de Amazon.';
                    message.style.color = 'red';
                    return;
                }
                // Crear un nuevo enlace con el código de afiliado
                const url = new URL(input);
                url.searchParams.set('tag', 'asesoriaecomm-21');
                // Redirigir
                window.location.href = url.toString();
            } catch (error) {
                message.textContent = 'El enlace no es válido. Inténtalo de nuevo.';
                message.style.color = 'red';
            }
        }
    </script>
</body>
</html>
